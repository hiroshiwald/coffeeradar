# Site protection: automatically enabled when OWNER_PASSWORD is set.
# To disable protection even with OWNER_PASSWORD set, use SITE_PROTECTION_ENABLED=false.

OWNER_USERNAME=          # Username for login and /owner admin panel.
OWNER_PASSWORD=          # Password for login and /owner admin panel. Setting this enables site protection.
SESSION_SECRET=          # Random string, min 32 chars. Used for HMAC-SHA-256 session signing.

# Optional
SITE_PROTECTION_ENABLED= # Set to "false" to explicitly disable site protection. Default: enabled when OWNER_PASSWORD is set.

# Database (Turso)
TURSO_DATABASE_URL=      # Turso database URL.
TURSO_AUTH_TOKEN=        # Turso auth token.
