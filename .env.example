# Required in production
SESSION_SECRET=          # Random string, min 32 chars. Used for HMAC-SHA-256 session signing.
OWNER_USERNAME=          # Username for the /owner admin panel (Basic Auth).
OWNER_PASSWORD=          # Password for /owner admin panel. Also used as session secret fallback.

# Optional
SITE_PROTECTION_ENABLED= # Set to "true" to require login for all public pages and API routes.
